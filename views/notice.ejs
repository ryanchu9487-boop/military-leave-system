<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>SmartMil - 공지사항</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        /* 滾動條美化 */
        .custom-scrollbar::-webkit-scrollbar { width: 5px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .custom-scrollbar:hover::-webkit-scrollbar-thumb { background: #94a3b8; }
        @import url("https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css");
        body { font-family: "Pretendard", sans-serif; }
        .mesh-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; overflow: hidden; background-color: #f8fafc; }
        .blob { position: absolute; filter: blur(90px); opacity: 0.65; animation: float 12s infinite alternate ease-in-out; }
        .blob-1 { top: -10%; left: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(99, 102, 241, 0.3) 0%, rgba(99, 102, 241, 0) 70%); }
        .blob-2 { bottom: -20%; right: -10%; width: 60vw; height: 60vw; background: radial-gradient(circle, rgba(168, 85, 247, 0.2) 0%, rgba(168, 85, 247, 0) 70%); animation-delay: -5s; }
        @keyframes float { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(30px, 50px) scale(1.1); } }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .heart-pop { animation: pop 0.3s ease-in-out; }
        @keyframes pop { 0% { transform: scale(1); } 50% { transform: scale(1.3); } 100% { transform: scale(1); } }
        .glass-card { background: rgba(255, 255, 255, 0.95); border: 1px solid rgba(255, 255, 255, 0.9); box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.05); border-radius: 1.5rem; }
    </style>
</head>
<body class="bg-gray-50 text-slate-800 overflow-hidden h-screen flex flex-col relative selection:bg-indigo-500 selection:text-white">

    <%- include('partials/sidebar') %>
    <%- include('partials/header') %>

    <div id="page-wrapper" class="flex-1 w-full h-full relative overflow-hidden flex flex-col transition-opacity duration-300">
        
        <div class="mesh-bg">
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
        </div>

        <div class="w-full max-w-2xl mx-auto px-4 pt-8 pb-4 flex justify-between items-center shrink-0 z-10">
           <h2 class="text-2xl font-black text-slate-800 tracking-tight"><i class="fa-solid fa-bullhorn text-indigo-500 mr-2"></i>공지사항</h2>
           <button id="createNoticeBtn" onclick="openCreateModal()" class="hidden bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl text-sm font-bold transition-all shadow-md flex items-center gap-2">
            <i class="fa-solid fa-pen"></i> 새 공지 등록
          </button>
        </div>

        <main class="flex-1 overflow-y-auto no-scrollbar pb-24 z-10" id="mainScrollArea">
          <div id="feedContainer" class="max-w-2xl mx-auto px-4 flex flex-col gap-6 pb-20">
            </div>
        </main>

        <div id="createModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden z-50 flex justify-center items-center opacity-0 transition-opacity p-4">
          <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden transform scale-95 transition-transform flex flex-col max-h-[90vh]" id="createModalContent">
            
            <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center bg-slate-50 shrink-0">
              <h2 id="modalTitle" class="text-lg font-black text-slate-800">새 공지 작성</h2>
              <button onclick="closeModal('createModal')" class="text-slate-400 hover:text-rose-500 transition-colors"><i class="fa-solid fa-xmark text-xl"></i></button>
            </div>
            
            <form id="noticeForm" class="p-6 flex flex-col gap-4 overflow-y-auto custom-scrollbar flex-1" onsubmit="submitNotice(event)">
              <input type="text" id="titleInput" required class="w-full font-bold text-lg border border-slate-200 rounded-xl focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none px-4 py-3 placeholder-slate-300 transition-all shrink-0" placeholder="공지 제목">
              
              <textarea id="contentInput" required rows="5" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none resize-none placeholder-slate-400 transition-all shrink-0" placeholder="전파할 내용을 작성해주세요..."></textarea>
              
              <div class="shrink-0">
                  <div class="border-2 border-dashed border-slate-300 rounded-xl p-4 bg-slate-50 hover:bg-slate-100 transition-colors cursor-pointer relative flex flex-col items-center justify-center gap-2" onclick="document.getElementById('fileInput').click()">
                    <i class="fa-solid fa-images text-indigo-400 text-2xl"></i>
                    <span id="fileCountText" class="text-slate-500 text-sm font-bold text-center">클릭하여 사진/파일 업로드<br><span class="text-xs text-slate-400">(여러 번 나누어 선택 가능, 최대 5개)</span></span>
                    <input type="file" id="fileInput" multiple accept="image/jpeg, image/png, image/gif, image/webp, .pdf, .doc, .docx, .xls, .xlsx, .hwp" class="hidden" onchange="handleNoticeFileSelect(this)">
                  </div>
                  
                  <div id="noticeSelectedFilesBox" class="mt-2 hidden">
                      <p class="text-xs font-bold text-slate-500 mb-1.5 flex justify-between">
                          <span>첨부 대기열 (<span id="noticeFileIndicator">0</span>/5)</span>
                          <button type="button" onclick="removeAllNoticeFiles()" class="text-rose-500 hover:underline">전체 삭제</button>
                      </p>
                      <div id="noticeFilePreviewList" class="flex flex-col gap-1.5"></div>
                  </div>
              </div>

              <div id="keyboardSpacer" class="w-full h-0 shrink-0 transition-all duration-300"></div>

              <div class="flex items-center justify-between mt-2 pt-2 border-t border-slate-100 shrink-0">
                <div class="flex items-center gap-2 bg-red-50 px-3 py-2 rounded-lg border border-red-100">
                  <input type="checkbox" id="importantCheck" class="w-4 h-4 text-red-500 rounded border-slate-300 focus:ring-red-500">
                  <label for="importantCheck" class="text-xs font-bold text-red-600 cursor-pointer">필독 공지</label>
                </div>
                <button type="submit" id="submitNoticeBtn" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl text-sm font-bold transition-all shadow-md flex items-center gap-2">
                    공유하기
                </button>
              </div>
            </form>

          </div>
        </div>

        <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/browser-image-compression@2.0.1/dist/browser-image-compression.js"></script>

        <script>
          var currentRole = "soldier";
          var currentUserId = "";
          var editNoticeId = null; 
          var selectedNoticeFiles = [];
          
          function getDisplayRank(user) {
              if (!user) return "";
              if (user.role !== "soldier" || !user.promoToIlbyung) {
                  let fallback = user.rank || "";
                  if(!fallback && user.role === 'soldier') return '용사';
                  if(!fallback && user.role === 'officer') return '간부';
                  return fallback;
              }
              const today = new Date();
              if (today >= new Date(user.promoToByungjang)) return "병장";
              if (today >= new Date(user.promoToSangbyung)) return "상병";
              if (today >= new Date(user.promoToIlbyung)) return "일병";
              return "이병";
          }

          async function handleNoticeFileSelect(input) {
              if (!input.files || input.files.length === 0) return;
              const newFiles = Array.from(input.files);
              let processedFiles = [];
              const options = { maxSizeMB: 1, maxWidthOrHeight: 1920, useWebWorker: true };
              const submitBtn = document.getElementById("submitNoticeBtn");
              
              submitBtn.disabled = true;
              submitBtn.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin"></i> 파일 처리 중...`;

              try {
                  for (let i = 0; i < newFiles.length; i++) {
                      let file = newFiles[i];
                      if (file.type.match(/image\/(jpeg|png|webp)/i)) {
                          try {
                              const compressedBlob = await imageCompression(file, options);
                              const compressedFile = new File([compressedBlob], file.name, { type: file.type });
                              processedFiles.push(compressedFile);
                          } catch (error) {
                              if (file.size > 10 * 1024 * 1024) {
                                  alert(`"${file.name}" 사진 용량이 너무 큽니다 (최대 10MB).`);
                                  continue; 
                              }
                              processedFiles.push(file); 
                          }
                      } else {
                          if (file.size > 10 * 1024 * 1024) {
                              alert(`"${file.name}" 파일이 너무 큽니다! (최대 10MB까지만 가능)`);
                              continue; 
                          }
                          processedFiles.push(file);
                      }
                  }

                  if (selectedNoticeFiles.length + processedFiles.length > 5) {
                      alert("첨부파일은 최대 5개까지만 업로드 가능합니다.");
                      const allowedCount = 5 - selectedNoticeFiles.length;
                      selectedNoticeFiles = selectedNoticeFiles.concat(processedFiles.slice(0, allowedCount));
                  } else {
                      selectedNoticeFiles = selectedNoticeFiles.concat(processedFiles);
                  }

                  input.value = ""; 
                  updateNoticeFileUI();
              } catch (error) {
                  console.error("파일 처리 오류:", error);
              } finally {
                  submitBtn.disabled = false;
                  submitBtn.innerHTML = editNoticeId ? `수정하기` : `공유하기`;
              }
          }

          function removeNoticeFile(index) { selectedNoticeFiles.splice(index, 1); updateNoticeFileUI(); }
          function removeAllNoticeFiles() { selectedNoticeFiles = []; updateNoticeFileUI(); }

          function updateNoticeFileUI() {
              const box = document.getElementById('noticeSelectedFilesBox');
              const list = document.getElementById('noticeFilePreviewList');
              const indicator = document.getElementById('noticeFileIndicator');
              list.innerHTML = '';
              indicator.innerText = selectedNoticeFiles.length;

              if (selectedNoticeFiles.length > 0) {
                  box.classList.remove('hidden');
                  selectedNoticeFiles.forEach((file, index) => {
                      const div = document.createElement('div');
                      div.className = "flex justify-between items-center bg-white border border-slate-200 px-3 py-2 rounded-lg shadow-sm";
                      let icon = file.type.startsWith('image/') ? '<i class="fa-solid fa-image text-indigo-400"></i>' : '<i class="fa-solid fa-file text-slate-400"></i>';
                      div.innerHTML = `
                          <div class="flex items-center gap-2 overflow-hidden text-sm">${icon}<span class="truncate text-slate-700 font-medium">${file.name}</span></div>
                          <button type="button" onclick="removeNoticeFile(${index})" class="text-slate-300 hover:text-rose-500 ml-2"><i class="fa-solid fa-xmark"></i></button>
                      `;
                      list.appendChild(div);
                  });
              } else {
                  box.classList.add('hidden');
              }
          }

          async function fetchNotices() {
            const token = localStorage.getItem("token");
            if (!token) return window.location.href = "/login.html";

            try {
              const res = await fetch("/api/notices", { headers: { Authorization: `Bearer ${token}` } });
              const data = await res.json();
              
              if (data.success) {
                currentRole = data.role;
                currentUserId = data.currentUserId;
                
                if (["officer", "reviewer", "approver", "admin", "superadmin"].includes(currentRole)) {
                  const createBtn = document.getElementById("createNoticeBtn");
                  if (createBtn) createBtn.classList.remove("hidden");
                }
                
                renderFeed(data.notices);

                if (typeof window.checkAndHighlightFocus === "function") {
                    setTimeout(window.checkAndHighlightFocus, 100);
                }
              }
            } catch (e) { console.error("Error:", e); }
          }

          // 🔥 智能排序與摺疊的 renderFeed
          function renderFeed(notices) {
            const container = document.getElementById("feedContainer");
            if (notices.length === 0) {
              container.innerHTML = `<div class="text-center text-slate-400 py-20"><i class="fa-solid fa-folder-open text-4xl mb-4 text-slate-300"></i><p class="font-bold text-base md:text-lg">등록된 공지사항이 없습니다.</p></div>`;
              return;
            }

            const importantNotices = notices.filter(n => n.isImportant);
            const normalNotices = notices.filter(n => !n.isImportant);
            let html = '';

            const createCardHtml = (n) => {
              const date = new Date(n.createdAt);
              const diffDays = Math.floor((new Date() - date) / (1000 * 60 * 60 * 24));
              const timeAgo = diffDays === 0 ? '오늘' : (diffDays < 30 ? `${diffDays}일 전` : date.toLocaleDateString());

              const isLiked = n.likes.some(u => (u._id || u).toString() === currentUserId.toString());
              const heartClass = isLiked ? 'fa-solid text-rose-500 heart-pop' : 'fa-regular text-slate-400 hover:text-slate-600';
              let likesListText = n.likes.length > 0 ? n.likes.map(u => `${getDisplayRank(u)} ${u.name || '알수없음'}`.trim()).join("<br>") : "아직 좋아요가 없습니다";
              
              const commentsHtml = n.comments.map(c => {
                const isCommentAuthor = (c.userId._id || c.userId).toString() === currentUserId.toString();
                const encodedText = encodeURIComponent(c.text);
                
                return `
                <div class="text-[13px] md:text-[15px] leading-relaxed flex items-start gap-1.5 md:gap-2 mb-1.5 group/comment">
                  <span class="font-black text-slate-800 whitespace-nowrap">${getDisplayRank(c.userId)} ${c.userId?.name || '익명'}</span>
                  <span class="text-slate-600 break-words flex-1">${c.text}</span>
                  
                  ${isCommentAuthor ? `
                  <button onclick="editNoticeComment('${n._id}', '${c._id}', '${encodedText}')" class="text-slate-300 hover:text-indigo-500 opacity-0 group-hover/comment:opacity-100 transition-opacity">
                    <i class="fa-solid fa-pen text-[10px]"></i>
                  </button>` : ''}
                </div>
              `}).join("");

              let imagesHtml = "", filesHtml = "";
              if (n.attachedFiles && n.attachedFiles.length > 0) {
                const images = n.attachedFiles.filter(f => f.match(/\.(jpg|jpeg|png|gif|webp)$/i));
                const docs = n.attachedFiles.filter(f => !f.match(/\.(jpg|jpeg|png|gif|webp)$/i));

                if (images.length > 0) {
                  imagesHtml = `<div class="mt-3 md:mt-4 grid ${images.length > 1 ? 'grid-cols-2' : 'grid-cols-1'} gap-1.5 md:gap-2">` + 
                    images.map(img => `<img src="${img}" class="w-full h-auto max-h-60 md:max-h-80 object-cover rounded-lg border border-slate-100 shadow-sm cursor-pointer hover:opacity-90" onclick="window.open('${img}', '_blank')" />`).join('') + `</div>`;
                }
                if (docs.length > 0) {
                  filesHtml = `<div class="mt-2.5 md:mt-3 flex flex-wrap gap-1.5 md:gap-2">` + docs.map(f => {
                    const displayName = f.split('/').pop().substring(f.split('/').pop().indexOf('-') + 1) || "첨부파일";
                    return `<a href="${f}" target="_blank" class="inline-flex items-center gap-1.5 bg-slate-100/80 border border-slate-200 px-2.5 py-1.5 rounded-lg text-xs font-bold text-indigo-600 shadow-sm"><i class="fa-solid fa-file-arrow-down"></i> ${displayName}</a>`;
                  }).join("") + `</div>`;
                }
              }

              const isAuthorControl = ["officer", "reviewer", "approver", "admin", "superadmin"].includes(currentRole);
              const authorIdStr = n.authorId ? (n.authorId._id || n.authorId).toString() : '';
              const isAuthor = authorIdStr === currentUserId.toString();
              const noticeDataStr = encodeURIComponent(JSON.stringify(n));
              const authorRank = getDisplayRank(n.authorId);

              return `
                <article id="item-${n._id}" class="glass-card overflow-hidden flex flex-col mb-4 md:mb-5"> 
                  <div class="p-4 md:p-5 border-b border-slate-100/50 shrink-0">
                    <div class="flex justify-between items-start mb-2.5 md:mb-3">
                      <div class="flex items-center gap-2.5 md:gap-3">
                        <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-gradient-to-tr from-indigo-500 to-purple-500 flex items-center justify-center text-white text-sm md:text-base font-black shadow-md">${(n.authorId?.name || '관').charAt(0)}</div>
                        <div class="flex flex-col"><span class="text-sm md:text-base font-black text-slate-800">${authorRank} ${n.authorId?.name || '관리자'}</span><span class="text-xs text-slate-400 font-bold">${timeAgo}</span></div>
                      </div>
                      <div class="flex items-center gap-2">
                        ${n.isImportant ? `<span class="bg-red-50 text-red-500 border border-red-200 px-2 py-0.5 rounded text-[11px] font-black tracking-wider">필독</span>` : ''}
                        ${isAuthor ? `<button onclick="openEditModal('${noticeDataStr}')" class="text-slate-400 hover:text-indigo-500 bg-slate-50 hover:bg-indigo-50 w-8 h-8 rounded-full flex items-center justify-center transition-colors"><i class="fa-solid fa-pen text-xs"></i></button>` : ''}
                        ${isAuthorControl || isAuthor ? `<button onclick="deleteNotice('${n._id}')" class="text-slate-400 hover:text-red-500 bg-slate-50 hover:bg-red-50 w-8 h-8 rounded-full flex items-center justify-center transition-colors"><i class="fa-solid fa-trash-can text-xs"></i></button>` : ''}
                      </div>
                    </div>
                    <h3 class="font-black text-lg md:text-xl text-slate-800 mb-1.5 leading-tight">${n.title}</h3>
                    <div class="max-h-[150px] md:max-h-[200px] overflow-y-auto custom-scrollbar pr-2"><p class="text-[15px] md:text-base text-slate-700 whitespace-pre-wrap leading-relaxed">${n.content}</p></div>
                    ${imagesHtml}
                    ${filesHtml}
                  </div>
                  <div class="px-4 py-2.5 flex items-center gap-3.5"><button onclick="toggleLike('${n._id}', this)" class="text-xl focus:outline-none transition-transform group"><i class="${heartClass} heart-icon fa-heart"></i></button><button onclick="focusCommentInput('${n._id}')" class="text-xl text-slate-400 hover:text-indigo-500 focus:outline-none"><i class="fa-regular fa-comment"></i></button></div>
                  <div class="px-4 pb-1 relative group w-max cursor-help"><span class="text-xs font-black text-slate-800 likes-count">좋아요 ${n.likes.length}개</span><div class="absolute left-0 bottom-full mb-2 hidden group-hover:block bg-slate-800/95 text-white text-xs font-bold px-3 py-2 rounded-lg shadow-xl z-20">${likesListText}</div></div>
                  <div class="px-4 pt-1"><span class="text-[11px] font-bold text-slate-400">댓글 ${n.comments.length}개</span></div>
                  <div class="px-4 pb-2 mt-1.5 overflow-y-auto custom-scrollbar max-h-[150px]" id="comment-list-${n._id}">${commentsHtml}</div>
                  <div class="px-4 py-2.5 border-t border-slate-100/50 flex items-center gap-2.5 bg-white/50"><input type="text" id="comment-${n._id}" class="flex-1 text-[14px] outline-none placeholder-slate-400 bg-transparent font-medium mobile-input" placeholder="댓글 달기..." onkeypress="handleCommentEnter(event, '${n._id}')"><button onclick="postComment('${n._id}')" class="text-indigo-600 text-[14px] font-black">게시</button></div>
                </article>
              `;
            };

            // 렌더링: 필독 공지
            if (importantNotices.length > 0) {
              const top5 = importantNotices.slice(0, 5);
              const rest = importantNotices.slice(5);
              html += `<div class="mb-8">
                         <div class="flex items-center gap-2 mb-3 px-2"><div class="w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse shadow-[0_0_8px_rgba(239,68,68,0.8)]"></div><h3 class="text-lg font-black text-slate-800">필독 공지</h3></div>
                         <div>${top5.map(n => createCardHtml(n)).join('')}</div>`;
              if (rest.length > 0) {
                html += `
                  <button onclick="document.getElementById('extraImportant').classList.toggle('hidden')" class="w-full py-3 mt-1 mb-4 bg-white border border-red-200 text-red-500 font-bold rounded-xl hover:bg-red-50 transition flex justify-center items-center gap-2 shadow-sm">
                      이전 필독 공지 ${rest.length}개 더보기 <i class="fa-solid fa-chevron-down"></i>
                  </button>
                  <div id="extraImportant" class="hidden flex flex-col">${rest.map(n => createCardHtml(n)).join('')}</div>`;
              }
              html += `</div><hr class="border-slate-200 mb-8 border-dashed" />`;
            }

            // 렌더링: 일반 공지
            if (normalNotices.length > 0) {
              const top5Normal = normalNotices.slice(0, 5);
              const restNormal = normalNotices.slice(5);

              html += `<div>
                         <div class="flex items-center gap-2 mb-3 px-2">
                             <div class="w-2.5 h-2.5 rounded-full bg-indigo-400"></div>
                             <h3 class="text-lg font-black text-slate-800">일반 공지</h3>
                         </div>
                         <div>${top5Normal.map(n => createCardHtml(n)).join('')}</div>`;
              
              if (restNormal.length > 0) {
                html += `
                  <button onclick="document.getElementById('extraNormal').classList.toggle('hidden')" class="w-full py-3 mt-1 mb-4 bg-white border border-indigo-200 text-indigo-500 font-bold rounded-xl hover:bg-indigo-50 transition flex justify-center items-center gap-2 shadow-sm">
                      이전 일반 공지 ${restNormal.length}개 더보기 <i class="fa-solid fa-chevron-down"></i>
                  </button>
                  <div id="extraNormal" class="hidden flex flex-col">${restNormal.map(n => createCardHtml(n)).join('')}</div>`;
              }
              html += `</div>`;
            }
            container.innerHTML = html;
          } // 🔥 這裡就是剛剛不見的下大括號！終於補上去了！

          async function submitNotice(e) {
            e.preventDefault();
            const token = localStorage.getItem("token");
            const btn = document.getElementById("submitNoticeBtn");
            const formData = new FormData();
            
            formData.append("title", document.getElementById("titleInput").value);
            formData.append("content", document.getElementById("contentInput").value);
            formData.append("isImportant", document.getElementById("importantCheck").checked);
            for(let i = 0; i < selectedNoticeFiles.length; i++) formData.append("files", selectedNoticeFiles[i]);

            btn.disabled = true;
            btn.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin"></i> 처리 중...`;

            const url = editNoticeId ? `/api/notices/${editNoticeId}` : "/api/notices";
            const method = editNoticeId ? "PUT" : "POST";

            try {
              const res = await fetch(url, { method: method, headers: { Authorization: `Bearer ${token}` }, body: formData });
              if ((await res.json()).success) {
                closeModal("createModal");
                fetchNotices(); 
              }
            } catch (err) { alert("오류 발생"); }
            finally { btn.disabled = false; }
          }

          async function toggleLike(id, btnEl) {
            const token = localStorage.getItem("token");
            const icon = btnEl.querySelector('.heart-icon');
            const countEl = btnEl.closest('article').querySelector('.likes-count');
            const isCurrentlyLiked = icon.classList.contains('fa-solid');
            let currentLikesCount = parseInt(countEl.innerText.replace(/[^0-9]/g, ''));

            if(isCurrentlyLiked) {
              icon.className = 'fa-regular fa-heart text-slate-400 hover:text-slate-600 heart-icon';
              currentLikesCount--;
            } else {
              icon.className = 'fa-solid fa-heart text-rose-500 heart-pop heart-icon';
              currentLikesCount++;
            }
            countEl.innerText = `좋아요 ${currentLikesCount}개`;
            try { await fetch(`/api/notices/${id}/like`, { method: "POST", headers: { Authorization: `Bearer ${token}` }}); } catch(e) { fetchNotices(); }
          }

          async function postComment(id) {
            const input = document.getElementById(`comment-${id}`);
            const text = input.value.trim();
            if(!text) return;
            try {
              const res = await fetch(`/api/notices/${id}/comment`, {
                method: "POST", headers: { "Content-Type": "application/json", Authorization: `Bearer ${localStorage.getItem("token")}` }, body: JSON.stringify({ text })
              });
              if((await res.json()).success) { input.value = ""; fetchNotices(); }
            } catch(e) {}
          }
          
          function handleCommentEnter(e, id) { if (e.key === 'Enter') postComment(id); }

          async function deleteNotice(id) {
            if(!confirm("이 공지를 삭제하시겠습니까?")) return;
            try {
              const res = await fetch(`/api/notices/${id}`, { method: "DELETE", headers: { Authorization: `Bearer ${localStorage.getItem("token")}` }});
              if((await res.json()).success) fetchNotices();
            } catch(e) {}
          }

          function showModal(id) {
            const el = document.getElementById(id);
            const content = document.getElementById(id + "Content");
            el.classList.remove("hidden");
            el.classList.add("flex");
            setTimeout(() => { el.classList.remove("opacity-0"); content.classList.remove("scale-95"); }, 10);
          }
          
          function closeModal(id) {
            const el = document.getElementById(id);
            const content = document.getElementById(id + "Content");
            el.classList.add("opacity-0");
            content.classList.add("scale-95");
            setTimeout(() => { el.classList.add("hidden"); el.classList.remove("flex"); }, 300);
          }
          
          function openCreateModal() { 
              editNoticeId = null;
              document.getElementById("noticeForm").reset();
              document.getElementById("modalTitle").innerText = "새 공지 작성";
              document.getElementById("submitNoticeBtn").innerHTML = "공유하기";
              removeAllNoticeFiles(); 
              showModal("createModal"); 
          }

          window.openEditModal = function(dataStr) {
              const notice = JSON.parse(decodeURIComponent(dataStr));
              editNoticeId = notice._id; 
              
              document.getElementById("titleInput").value = notice.title;
              document.getElementById("contentInput").value = notice.content;
              document.getElementById("importantCheck").checked = notice.isImportant;
              
              document.getElementById("modalTitle").innerText = "공지 수정";
              document.getElementById("submitNoticeBtn").innerHTML = "수정하기";
              removeAllNoticeFiles(); 
              showModal("createModal"); 
          };

          function handleMobileFocus(inputEl) {
              const spacer = document.getElementById('keyboardSpacer');
              if(spacer && window.innerWidth < 768) {
                  spacer.style.height = '40vh';
                  setTimeout(() => { inputEl.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 300);
              }
          }

          function handleMobileBlur() {
              const spacer = document.getElementById('keyboardSpacer');
              if(spacer) spacer.style.height = '0px';
          }

          function focusCommentInput(id) {
              const input = document.getElementById(`comment-${id}`);
              if(input) input.focus();
          }

          document.addEventListener('DOMContentLoaded', () => {
              const formInputs = ['titleInput', 'contentInput'];
              formInputs.forEach(id => {
                  const el = document.getElementById(id);
                  if(el) {
                      el.addEventListener('focus', function() { handleMobileFocus(this); });
                      el.addEventListener('blur', handleMobileBlur);
                  }
              });

              document.body.addEventListener('focus', (e) => {
                  if (e.target && e.target.classList.contains('mobile-input')) {
                      setTimeout(() => { e.target.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 300);
                  }
              }, true);
          });

          setTimeout(() => {
            fetchNotices();
            if(typeof fetchNotifications === "function") fetchNotifications(); 
          }, 50);

          // 🔥 修改公告留言
          async function editNoticeComment(noticeId, commentId, oldTextEncoded) {
              const oldText = decodeURIComponent(oldTextEncoded);
              const newText = prompt("댓글 수정 (修改留言):", oldText);
              
              if (newText && newText.trim() !== "" && newText !== oldText) {
                  try {
                      const token = localStorage.getItem("token");
                      const res = await fetch(`/api/notices/${noticeId}/comment/${commentId}`, {
                          method: "PUT",
                          headers: { "Content-Type": "application/json", Authorization: `Bearer ${token}` },
                          body: JSON.stringify({ text: newText.trim() })
                      });
                      if ((await res.json()).success) fetchNotices(); // 刷新畫面
                  } catch(e) { alert("댓글 수정 실패"); }
              }
          }

        </script>
    </div>
    <script src="/common.js" onerror="console.log('common.js not found')"></script>
</body>
</html>