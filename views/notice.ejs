<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SmartMil - 공지사항</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        /* 滾動條美化 */
        .custom-scrollbar::-webkit-scrollbar { width: 5px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .custom-scrollbar:hover::-webkit-scrollbar-thumb { background: #94a3b8; }
        @import url("https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css");
        body { font-family: "Pretendard", sans-serif; }
        .mesh-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; overflow: hidden; background-color: #f8fafc; }
        .blob { position: absolute; filter: blur(90px); opacity: 0.65; animation: float 12s infinite alternate ease-in-out; }
        .blob-1 { top: -10%; left: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(99, 102, 241, 0.3) 0%, rgba(99, 102, 241, 0) 70%); }
        .blob-2 { bottom: -20%; right: -10%; width: 60vw; height: 60vw; background: radial-gradient(circle, rgba(168, 85, 247, 0.2) 0%, rgba(168, 85, 247, 0) 70%); animation-delay: -5s; }
        @keyframes float { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(30px, 50px) scale(1.1); } }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .heart-pop { animation: pop 0.3s ease-in-out; }
        @keyframes pop { 0% { transform: scale(1); } 50% { transform: scale(1.3); } 100% { transform: scale(1); } }
        .glass-card { background: rgba(255, 255, 255, 0.95); border: 1px solid rgba(255, 255, 255, 0.9); box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.05); border-radius: 1.5rem; }
    </style>
</head>
<body class="bg-gray-50 text-slate-800 overflow-hidden h-screen flex flex-col relative selection:bg-indigo-500 selection:text-white">

    <%- include('partials/sidebar') %>
    <%- include('partials/header') %>

    <div id="page-wrapper" class="flex-1 w-full h-full relative overflow-hidden flex flex-col transition-opacity duration-300">
        
        <div class="mesh-bg">
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
        </div>

        <div class="w-full max-w-2xl mx-auto px-4 pt-8 pb-4 flex justify-between items-center shrink-0 z-10">
           <h2 class="text-2xl font-black text-slate-800 tracking-tight"><i class="fa-solid fa-bullhorn text-indigo-500 mr-2"></i>공지사항</h2>
           <button id="createNoticeBtn" onclick="openCreateModal()" class="hidden bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl text-sm font-bold transition-all shadow-md flex items-center gap-2">
            <i class="fa-solid fa-pen"></i> 새 공지 등록
          </button>
        </div>

        <main class="flex-1 overflow-y-auto no-scrollbar pb-20 z-10">
          <div id="feedContainer" class="max-w-2xl mx-auto px-4 flex flex-col gap-6">
            </div>
        </main>

        <div id="createModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden z-50 flex justify-center items-center opacity-0 transition-opacity">
          <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden transform scale-95 transition-transform" id="createModalContent">
            <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center bg-slate-50">
              <h2 class="text-lg font-black text-slate-800">새 공지 작성</h2>
              <button onclick="closeModal('createModal')" class="text-slate-400 hover:text-rose-500 transition-colors"><i class="fa-solid fa-xmark text-xl"></i></button>
            </div>
            <form id="noticeForm" class="p-6 flex flex-col gap-4" onsubmit="submitNotice(event)">
              <input type="text" id="titleInput" required class="w-full font-bold text-lg border border-slate-200 rounded-xl focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none px-4 py-3 placeholder-slate-300 transition-all" placeholder="공지 제목">
              
              <textarea id="contentInput" required rows="6" class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none resize-none placeholder-slate-400 transition-all" placeholder="전파할 내용을 작성해주세요..."></textarea>
              
              <div class="border border-dashed border-slate-300 rounded-xl p-4 bg-slate-50 hover:bg-slate-100 transition-colors cursor-pointer relative mt-1">
                <input type="file" id="fileInput" multiple class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" onchange="updateFileCount()">
                <div class="flex items-center justify-center gap-3 text-slate-500 text-sm font-bold">
                  <i class="fa-solid fa-cloud-arrow-up text-indigo-400 text-xl"></i>
                  <span id="fileCountText">클릭하여 첨부파일 업로드 (최대 5개)</span>
                </div>
              </div>

              <div class="flex items-center justify-between mt-2">
                <div class="flex items-center gap-2 bg-red-50 px-3 py-2 rounded-lg border border-red-100">
                  <input type="checkbox" id="importantCheck" class="w-4 h-4 text-red-500 rounded border-slate-300 focus:ring-red-500">
                  <label for="importantCheck" class="text-xs font-bold text-red-600 cursor-pointer">필독 공지</label>
                </div>
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl text-sm font-bold transition-all shadow-md">공유하기</button>
              </div>
            </form>
          </div>
        </div>

        <script>
          var currentRole = "soldier";
          var currentUserId = "";

          function updateFileCount() {
            const files = document.getElementById("fileInput").files;
            const text = document.getElementById("fileCountText");
            if(files.length > 0) text.innerText = `${files.length}개의 파일이 선택되었습니다.`;
            else text.innerText = "클릭하여 첨부파일 업로드 (최대 5개)";
          }

          async function fetchNotices() {
            const token = localStorage.getItem("token");
            if (!token) return window.location.href = "/login.html";

            try {
              const res = await fetch("/api/notices", { headers: { Authorization: `Bearer ${token}` } });
              const data = await res.json();
              
              if (data.success) {
                currentRole = data.role;
                currentUserId = data.currentUserId;
                
                if (["officer", "reviewer", "approver", "admin", "superadmin"].includes(currentRole)) {
                  const createBtn = document.getElementById("createNoticeBtn");
                  if (createBtn) createBtn.classList.remove("hidden");
                }
                renderFeed(data.notices);
              }
            } catch (e) { console.error("Error:", e); }
          }

          // 🔥 升級版 IG 風格動態牆
function renderFeed(notices) {
  const container = document.getElementById("feedContainer");
  if (notices.length === 0) {
    container.innerHTML = `<div class="text-center text-slate-400 py-20"><i class="fa-solid fa-folder-open text-4xl mb-4 text-slate-300"></i><p class="font-bold">등록된 공지사항이 없습니다.</p></div>`;
    return;
  }

  container.innerHTML = notices.map(n => {
    const date = new Date(n.createdAt);
    const diffDays = Math.floor((new Date() - date) / (1000 * 60 * 60 * 24));
    const timeAgo = diffDays === 0 ? '오늘' : (diffDays < 30 ? `${diffDays}일 전` : date.toLocaleDateString());

    // 1. 判斷是否按讚
    const isLiked = n.likes.some(u => (u._id || u).toString() === currentUserId.toString());
    const heartClass = isLiked ? 'fa-solid text-rose-500 heart-pop' : 'fa-regular text-slate-400 hover:text-slate-600';
    
    // 2. 準備按讚名單文字 (Tooltip用)
    let likesListText = "아직 좋아요가 없습니다";
    if (n.likes.length > 0) {
        likesListText = n.likes.map(u => `${u.rank || ''} ${u.name || '알수없음'}`).join("<br>");
    }

    // 3. 留言區
    const commentsHtml = n.comments.map(c => `
      <div class="text-[13px] leading-relaxed flex items-start gap-2 mb-1.5">
        <span class="font-black text-slate-800 whitespace-nowrap">${c.userId?.rank || ''} ${c.userId?.name || '익명'}</span>
        <span class="text-slate-600 break-words flex-1">${c.text}</span>
      </div>
    `).join("");

    // 🔥 4. 智慧判斷：分離圖片與一般文件
    let imagesHtml = "";
    let filesHtml = "";
    if (n.attachedFiles && n.attachedFiles.length > 0) {
      
      // 用副檔名判斷是不是圖片
      const images = n.attachedFiles.filter(f => f.match(/\.(jpg|jpeg|png|gif|webp)$/i));
      const docs = n.attachedFiles.filter(f => !f.match(/\.(jpg|jpeg|png|gif|webp)$/i));

      // 如果有圖片，直接顯示大圖 (如果超過一張，自動變成雙排網格)
      if (images.length > 0) {
        const gridClass = images.length > 1 ? 'grid-cols-2' : 'grid-cols-1';
        imagesHtml = `<div class="mt-4 grid ${gridClass} gap-2">` + 
          images.map(img => `<img src="${img}" class="w-full h-auto max-h-80 object-cover rounded-xl border border-slate-100 shadow-sm cursor-pointer hover:opacity-90 transition-opacity" onclick="window.open('${img}', '_blank')" />`).join('') + 
        `</div>`;
      }

      // 如果有文件，維持原本的下載按鈕 (換成 file-arrow-down 圖示更直覺)
      if (docs.length > 0) {
        filesHtml = `<div class="mt-3 flex flex-wrap gap-2">` + 
          docs.map(f => {
            const rawName = f.split('/').pop();
            const displayName = rawName.substring(rawName.indexOf('-') + 1) || "첨부파일";
            return `<a href="${f}" target="_blank" class="inline-flex items-center gap-1.5 bg-slate-100/80 border border-slate-200 px-3 py-1.5 rounded-lg text-xs font-bold text-indigo-600 hover:bg-indigo-50 transition shadow-sm"><i class="fa-solid fa-file-arrow-down"></i> ${displayName}</a>`;
          }).join("") + `</div>`;
      }
    }

    const isAuthorControl = ["officer", "reviewer", "approver", "admin", "superadmin"].includes(currentRole);

    return `
      <article class="glass-card overflow-hidden flex flex-col max-h-[750px]"> 
        <div class="p-5 border-b border-slate-100/50 shrink-0">
          <div class="flex justify-between items-start mb-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-indigo-500 to-purple-500 flex items-center justify-center text-white text-sm font-black shadow-md">
                ${(n.authorId?.name || '관').charAt(0)}
              </div>
              <div class="flex flex-col">
                <span class="text-[14px] font-black text-slate-800">${n.authorId?.rank || ''} ${n.authorId?.name || '관리자'}</span>
                <span class="text-[11px] text-slate-400 font-bold tracking-wide">${timeAgo}</span>
              </div>
            </div>
            <div class="flex items-center gap-2">
              ${n.isImportant ? `<span class="bg-red-50 text-red-500 border border-red-200 px-2 py-0.5 rounded text-[10px] font-black tracking-wider shadow-sm">필독</span>` : ''}
              ${isAuthorControl ? `<button onclick="deleteNotice('${n._id}')" class="text-slate-300 hover:text-red-500 transition-colors"><i class="fa-solid fa-trash-can"></i></button>` : ''}
            </div>
          </div>
          
          <h3 class="font-black text-lg text-slate-800 mb-2 leading-tight">${n.title}</h3>
          
          <div class="max-h-[200px] overflow-y-auto custom-scrollbar pr-2">
            <p class="text-[14px] text-slate-600 whitespace-pre-wrap leading-relaxed">${n.content}</p>
          </div>
          
          ${imagesHtml}
          
          ${filesHtml}
        </div>

        <div class="px-5 py-3 flex items-center gap-4 shrink-0">
          <button onclick="toggleLike('${n._id}', this)" class="text-2xl focus:outline-none transition-transform flex items-center gap-2 group">
            <i class="${heartClass} heart-icon fa-heart"></i>
          </button>
          <button onclick="document.getElementById('comment-${n._id}').focus()" class="text-2xl text-slate-400 hover:text-indigo-500 transition-colors focus:outline-none">
            <i class="fa-regular fa-comment"></i>
          </button>
        </div>

        <div class="px-5 pb-1 relative group w-max cursor-help shrink-0">
          <span class="text-[12px] font-black text-slate-800 likes-count">좋아요 ${n.likes.length}개</span>
          
          <div class="absolute left-0 bottom-full mb-2 hidden group-hover:block bg-slate-800/95 backdrop-blur-sm text-white text-[11px] font-bold px-3 py-2.5 rounded-lg shadow-xl z-20 pointer-events-none max-w-[200px] max-h-[150px] overflow-y-auto custom-scrollbar">
            ${likesListText}
          </div>
        </div>

        <div class="px-5 pt-2 flex items-center justify-between shrink-0">
            <span class="text-[11px] font-bold text-slate-400">댓글 ${n.comments.length}개</span>
        </div>

        <div class="px-5 pb-2 mt-2 overflow-y-auto custom-scrollbar flex-1 min-h-[50px] max-h-[180px]" id="comment-list-${n._id}">
          ${commentsHtml}
        </div>

        <div class="px-5 py-3 border-t border-slate-100/50 flex items-center gap-3 bg-white/50 shrink-0">
          <input type="text" id="comment-${n._id}" class="flex-1 text-sm outline-none placeholder-slate-400 bg-transparent font-medium" placeholder="댓글 달기..." onkeypress="handleCommentEnter(event, '${n._id}')">
          <button onclick="postComment('${n._id}')" class="text-indigo-600 text-sm font-black hover:text-indigo-800 transition-colors">게시</button>
        </div>
      </article>
    `;
  }).join("");
}

          async function submitNotice(e) {
            e.preventDefault();
            const token = localStorage.getItem("token");
            const formData = new FormData();
            formData.append("title", document.getElementById("titleInput").value);
            formData.append("content", document.getElementById("contentInput").value);
            formData.append("isImportant", document.getElementById("importantCheck").checked);
            const files = document.getElementById("fileInput").files;
            for(let i = 0; i < files.length; i++) formData.append("files", files[i]);

            try {
              const res = await fetch("/api/notices", { method: "POST", headers: { Authorization: `Bearer ${token}` }, body: formData });
              if ((await res.json()).success) {
                closeModal("createModal");
                document.getElementById("noticeForm").reset();
                document.getElementById("fileCountText").innerText = "클릭하여 첨부파일 업로드 (최대 5개)";
                fetchNotices();
              }
            } catch (err) { alert("오류 발생"); }
          }

          async function toggleLike(id, btnEl) {
            const token = localStorage.getItem("token");
            const icon = btnEl.querySelector('.heart-icon');
            const countEl = btnEl.closest('article').querySelector('.likes-count');
            const isCurrentlyLiked = icon.classList.contains('fa-solid');
            let currentLikesCount = parseInt(countEl.innerText.replace(/[^0-9]/g, ''));

            if(isCurrentlyLiked) {
              icon.className = 'fa-regular fa-heart text-slate-400 hover:text-slate-600 heart-icon';
              currentLikesCount--;
            } else {
              icon.className = 'fa-solid fa-heart text-rose-500 heart-pop heart-icon';
              currentLikesCount++;
            }
            countEl.innerText = `좋아요 ${currentLikesCount}개`;
            try { await fetch(`/api/notices/${id}/like`, { method: "POST", headers: { Authorization: `Bearer ${token}` }}); } catch(e) { fetchNotices(); }
          }

          async function postComment(id) {
            const input = document.getElementById(`comment-${id}`);
            const text = input.value.trim();
            if(!text) return;
            try {
              const res = await fetch(`/api/notices/${id}/comment`, {
                method: "POST", headers: { "Content-Type": "application/json", Authorization: `Bearer ${localStorage.getItem("token")}` }, body: JSON.stringify({ text })
              });
              if((await res.json()).success) { input.value = ""; fetchNotices(); }
            } catch(e) {}
          }
          function handleCommentEnter(e, id) { if (e.key === 'Enter') postComment(id); }

          async function deleteNotice(id) {
            if(!confirm("이 공지를 삭제하시겠습니까?")) return;
            try {
              const res = await fetch(`/api/notices/${id}`, { method: "DELETE", headers: { Authorization: `Bearer ${localStorage.getItem("token")}` }});
              if((await res.json()).success) fetchNotices();
            } catch(e) {}
          }

          function showModal(id) {
            const el = document.getElementById(id);
            const content = document.getElementById(id + "Content");
            el.classList.remove("hidden");
            setTimeout(() => { el.classList.remove("opacity-0"); content.classList.remove("scale-95"); }, 10);
          }
          function closeModal(id) {
            const el = document.getElementById(id);
            const content = document.getElementById(id + "Content");
            el.classList.add("opacity-0");
            content.classList.add("scale-95");
            setTimeout(() => el.classList.add("hidden"), 300);
          }
          function openCreateModal() { showModal("createModal"); }

          // 🔥 修改點 3：無論是 F5 進入還是 SPA 動態載入，直接觸發函式！
          // 因為 SPA 載入腳本時 window.onload 早就失效了
          setTimeout(() => {
            fetchNotices();
            // 如果你的系統有抓取 Header 鈴鐺數量的函數，在這裡一起呼叫
            if(typeof fetchNotifications === "function") fetchNotifications(); 
          }, 50);

        </script>
    </div>
    <script src="/common.js" onerror="console.log('common.js not found')"></script>
</body>
</html>