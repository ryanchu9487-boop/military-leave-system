<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <title>SmartMil - 부대 출타 관리 시스템</title>
    <style>
        @import url("https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css");
        body { font-family: "Pretendard", sans-serif; }
        .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        #calendar::-webkit-scrollbar { display: none; }
        #calendar { -ms-overflow-style: none; scrollbar-width: none; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }

        @media (max-width: 639px) {
            .calendar-grid.bg-gray-50 > div { font-size: 0.7rem !important; padding: 0.3rem 0 !important; }
            .week-row { min-height: 80px !important; }
            .day-cell { padding: 0.25rem !important; }
            .date-text { font-size: 0.7rem !important; min-width: 20px !important; width: auto !important; padding: 0 4px !important; height: 20px !important; display: inline-flex !important; align-items: center !important; justify-content: center !important; border-radius: 10px !important; white-space: nowrap !important; letter-spacing: -0.5px !important; }
            .holiday-name { font-size: 0.55rem !important; margin-top: 1px !important; width: 100% !important; display: block !important; white-space: normal !important; word-break: keep-all !important; line-height: 1.1 !important; max-height: 16px !important; overflow: hidden !important; text-align: center !important; }
            .event-layer { top: 24px !important; }
            .event-layer > div { height: 14px !important; margin-bottom: 2px !important; }
            [class*="leave-bar-"] { height: 14px !important; font-size: 8px !important; line-height: 14px !important; padding: 0 4px !important; border-radius: 3px !important; }
            #notificationDropdown { position: fixed !important; top: 60px !important; left: 50% !important; transform: translateX(-50%) !important; width: 92vw !important; max-height: 75vh !important; z-index: 9999 !important; }
            #floatingPill { top: 54px !important; transform: translateX(-50%) scale(0.85) !important; padding: 4px 10px !important; white-space: nowrap !important; }
            #floatingYearMonth { font-size: 0.85rem !important; letter-spacing: -0.5px !important; }
            #miniPickerBox { width: 200px !important; transform: translateX(-50%) scale(0.9) !important; }
        }

        /* 這裡保留您的其他 CSS 樣式 (spotlight-target 等)... */
        [class*="leave-bar-"] { transition: all 0.4s ease !important; }
        .spotlight-dimmed { opacity: 0.25 !important; transition: opacity 0.4s ease !important; pointer-events: none; }
        .spotlight-target { transform: scale(1.08) !important; z-index: 100 !important; box-shadow: 0 6px 16px rgba(0, 0, 0, 0.2) !important; transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) !important; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 overflow-hidden h-screen flex flex-col">
    <%- include('partials/sidebar') %>
    <%- include('partials/header') %>

    <div id="page-wrapper" class="flex-1 w-full h-full relative overflow-hidden flex flex-col">
        
        <main class="flex-1 overflow-hidden p-4 sm:p-6 relative flex flex-col gap-4 z-10">
            <div id="calendarToggle" class="hidden flex justify-center items-center gap-1.5 bg-gray-200 p-1 rounded-lg w-fit mx-auto">
                <button onclick="switchCalendarMode('personal')" id="btnPersonal" class="...">내 휴가</button>
                <button onclick="switchCalendarMode('team-long')" id="btnTeamLong" class="...">전체 (휴가)</button>
                <button onclick="switchCalendarMode('team-short')" id="btnTeamShort" class="...">전체 (외출/외박)</button>
                <button id="settingsModalBtn" onclick="openModal('rateModal')" class="hidden px-3 py-2 text-sm font-bold text-gray-500 hover:text-indigo-600 transition"><i class="fa-solid fa-gear"></i></button>
                <button id="batchApproveBtn" onclick="batchApprovePhase1()" class="hidden px-4 py-1.5 bg-orange-500 text-white shadow-sm rounded-md text-sm font-bold hover:bg-orange-600 transition flex items-center"><i class="fa-solid fa-check-double mr-1.5"></i>일괄결재</button>
            </div>

            <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden h-full flex flex-col relative pt-16">
                <div class="calendar-grid bg-gray-50 border-b border-gray-200 text-center py-2 text-xs font-bold text-gray-500 uppercase tracking-wider relative z-20">
                    <div class="text-red-500 border-r border-gray-200">일</div>
                    <div class="border-r border-gray-200">월</div>
                    <div class="border-r border-gray-200">화</div>
                    <div class="border-r border-gray-200">수</div>
                    <div class="border-r border-gray-200">목</div>
                    <div class="border-r border-gray-200">금</div>
                    <div class="text-blue-500">토</div>
                </div>
                <div id="calendar" class="flex-1 calendar-grid divide-x divide-y divide-gray-100 relative overflow-y-auto"></div>
            </div>
        </main>

        <div class="fixed bottom-6 right-6 md:bottom-10 md:right-10 z-[50] flex flex-col items-end gap-3">
            <div id="fabMenu" class="flex flex-col gap-3 items-end transition-all duration-300 opacity-0 translate-y-4 pointer-events-none">
                <button id="fabGrantBtn" onclick="openModal('grantModal')" class="flex items-center gap-3 group focus:outline-none">
                    <span class="bg-white px-3 py-1.5 rounded-lg text-sm font-bold text-gray-700 shadow-md group-hover:text-indigo-600 transition-colors">출타 심의 (등록)</span>
                    <div class="w-10 h-10 bg-white text-indigo-600 rounded-full flex items-center justify-center shadow-lg group-hover:bg-indigo-50 transition-colors"><i class="fa-solid fa-gavel text-sm"></i></div>
                </button>
                <button onclick="openModal('requestModal')" class="flex items-center gap-3 group focus:outline-none">
                    <span class="bg-white px-3 py-1.5 rounded-lg text-sm font-bold text-gray-700 shadow-md group-hover:text-indigo-600 transition-colors">출타 신청 (사용)</span>
                    <div class="w-10 h-10 bg-white text-indigo-600 rounded-full flex items-center justify-center shadow-lg group-hover:bg-indigo-50 transition-colors"><i class="fa-solid fa-plane-departure text-sm"></i></div>
                </button>
            </div>
            <button onclick="toggleFabMenu()" id="mainFab" class="w-14 h-14 bg-indigo-600 text-white rounded-full flex items-center justify-center text-xl shadow-[0_10px_25px_rgba(99,102,241,0.5)] hover:bg-indigo-700 hover:-translate-y-1 transition-all duration-300 focus:outline-none">
                <i class="fa-solid fa-plus transition-transform duration-300" id="fabIcon"></i>
            </button>
        </div>

        <div id="grantModal" onclick="closeModal('grantModal')" class="hidden fixed inset-0 bg-gray-900/40 backdrop-blur-sm z-[100] flex items-center justify-center p-4">...</div>
        <div id="requestModal" onclick="closeModal('requestModal')" class="hidden fixed inset-0 bg-gray-900/40 backdrop-blur-sm z-[100] flex items-center justify-center p-4">...</div>
        <div id="rateModal" onclick="closeModal('rateModal')" class="hidden fixed inset-0 bg-gray-900/40 backdrop-blur-sm z-[100] flex items-center justify-center p-4">...</div>
        <div id="bottomSheetOverlay" class="fixed inset-0 bg-black/50 z-[110] hidden opacity-0 transition-opacity duration-300" onclick="closeBottomSheet()"></div>
        <div id="bottomSheet" class="fixed bottom-0 left-0 right-0 bg-white rounded-t-3xl shadow-2xl z-[120] transform translate-y-full transition-transform duration-300 flex flex-col max-h-[85vh]">...</div>

    </div> <script src="/common.js"></script>
    <script>
        // 這裡放您原本 index.ejs 裡面的 script 內容...
    </script>
    <script src="/calendar.js"></script>
</body>
</html>