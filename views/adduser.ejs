<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SmartMil - 부대원 관리</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        @import url("https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css");
        body { font-family: "Pretendard", sans-serif; }
        .mesh-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; overflow: hidden; background-color: #f8fafc; }
        .blob { position: absolute; filter: blur(90px); opacity: 0.65; animation: float 12s infinite alternate ease-in-out; }
        .blob-1 { top: -10%; left: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(99, 102, 241, 0.3) 0%, rgba(99, 102, 241, 0) 70%); }
        .blob-2 { bottom: -20%; right: -10%; width: 60vw; height: 60vw; background: radial-gradient(circle, rgba(168, 85, 247, 0.2) 0%, rgba(168, 85, 247, 0) 70%); animation-delay: -5s; }
        @keyframes float { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(30px, 50px) scale(1.1); } }
        #pendingList > div, #userList > div { background: rgba(255, 255, 255, 0.6) !important; backdrop-filter: blur(16px) !important; border: 1px solid rgba(255, 255, 255, 0.8) !important; box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.05), inset 0 2px 10px rgba(255, 255, 255, 0.8) !important; border-radius: 1.5rem !important; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1) !important; margin-bottom: 0.75rem !important; padding: 1rem 1.25rem !important; }
        /* 這裡保留您的其他 CSS... */
    </style>
</head>
<body class="bg-gray-50 text-slate-800 overflow-hidden h-screen flex flex-col relative selection:bg-indigo-500 selection:text-white">

    <%- include('partials/sidebar') %>
    <%- include('partials/header') %>

    <div id="page-wrapper" class="flex-1 w-full h-full relative overflow-hidden flex flex-col">
        
        <div class="mesh-bg">
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
        </div>

        <main class="flex-1 overflow-y-auto custom-scrollbar w-full relative z-10">
            <div class="max-w-5xl mx-auto pt-10 px-4 sm:px-6 pb-20">
                <div class="flex flex-col sm:flex-row justify-between items-end gap-5 mb-10">
                    <div>
                        <h2 id="unitTitleDisplay" class="text-3xl sm:text-4xl font-black text-gray-900 tracking-tight mb-2">
                            소속 부대 <span class="text-indigo-600 font-light">조직도</span>
                        </h2>
                        <p class="text-gray-500 font-medium">조직원의 권한을 설정하고 가입 요청을 승인합니다.</p>
                    </div>
                </div>

                <section id="pendingSection" class="mb-12 hidden">
                    <div id="pendingList" class="space-y-0"></div>
                </section>

                <section>
                    <div id="userList" class="space-y-0"></div>
                </section>
            </div>
        </main>

        <div id="hrModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4">
            <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" onclick="closeHrModal()"></div>
            <div class="modal-animate relative w-full max-w-md bg-white rounded-[2rem] shadow-2xl border border-gray-100 overflow-hidden flex flex-col max-h-[90vh]">
                </div>
        </div>

        <input type="hidden" id="currentHrUserId" value="" />
        <script src="/js/adduser.js"></script>

    </div> <script src="/common.js"></script>
    <script>
        function closeHrModal() {
            document.getElementById("hrModal").classList.add("hidden");
        }

        // 在 adduser.ejs 的 <script> 內
window.initAddUserPage = function() {
    console.log("人員管理頁重新初始化...");
    if (typeof fetchUsers === "function") fetchUsers();
};

// 為了讓 SPA 引擎能抓到，也可以直接在 DOMContentLoaded 呼叫
document.addEventListener("DOMContentLoaded", window.initAddUserPage);
    </script>
</body>
</html>