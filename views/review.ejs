<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SmartMil - 출타 심의 (검토)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
      @import url("https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css");
      body { font-family: "Pretendard", sans-serif; }
      .mesh-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; overflow: hidden; background-color: #f8fafc; transition: background-color 0.5s ease; }
      .blob { position: absolute; filter: blur(80px); opacity: 0.6; animation: float 10s infinite alternate ease-in-out; transition: background 0.5s ease; }
      .blob-1 { top: -10%; left: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(99, 102, 241, 0.3) 0%, rgba(99, 102, 241, 0) 70%); }
      .blob-2 { bottom: -20%; right: -10%; width: 60vw; height: 60vw; background: radial-gradient(circle, rgba(59, 130, 246, 0.25) 0%, rgba(59, 130, 246, 0) 70%); animation-delay: -5s; }
      .cancel-mode .mesh-bg { background-color: #fffaf5; }
      .cancel-mode .blob-1 { background: radial-gradient(circle, rgba(249, 115, 22, 0.3) 0%, rgba(249, 115, 22, 0) 70%); }
      .cancel-mode .blob-2 { background: radial-gradient(circle, rgba(239, 68, 68, 0.25) 0%, rgba(239, 68, 68, 0) 70%); }
      @keyframes float { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(30px, 50px) scale(1.1); } }
      .glass-card { animation: slideUpFade 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
      @keyframes slideUpFade { 0% { opacity: 0; transform: translateY(20px) scale(0.98); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
      .custom-scrollbar::-webkit-scrollbar { width: 6px; }
      .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
    </style>
  </head>
  <body class="bg-transparent text-slate-800 overflow-hidden h-screen flex flex-col selection:bg-indigo-500 selection:text-white" id="mainBody">
    
    <div class="mesh-bg">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
    </div>

    <%- include('partials/sidebar') %>
    <%- include('partials/header') %>

    <div id="page-wrapper" class="flex-1 w-full relative overflow-y-auto custom-scrollbar scroll-smooth">
      <div class="min-h-full w-full flex items-start justify-center p-4 sm:p-8 py-10">
        
        <div class="glass-card max-w-2xl w-full bg-white/75 backdrop-blur-2xl border border-white/60 shadow-[0_24px_60px_-15px_rgba(0,0,0,0.1)] rounded-[2.5rem] p-8 sm:p-10 relative h-fit z-20 m-auto">
          <button onclick="spaNavigate('/')" class="absolute top-6 right-6 w-10 h-10 flex items-center justify-center rounded-full bg-gray-100/50 hover:bg-gray-200 text-gray-400 transition-all z-20">
            <i class="fa-solid fa-xmark text-lg"></i>
          </button>

          <div class="mb-8">
            <div id="statusBadge" class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-100/50 border border-indigo-200 text-indigo-700 text-xs font-bold tracking-wider mb-4 shadow-sm transition-colors">
              <i class="fa-solid fa-file-signature"></i>
              <span id="unitNameDisplay">소속부대</span>
            </div>
            <h1 class="text-3xl font-black tracking-tight text-gray-900" id="mainTitle">
              출타 심의 <span class="text-indigo-600 font-light" id="subTitle">검토</span>
            </h1>
          </div>

          <div id="loading" class="text-center py-20">
            <div class="w-8 h-8 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin mx-auto mb-4"></div>
          </div>

          <div id="leave-content" class="hidden space-y-8">
            <div class="flex items-center gap-5 p-5 rounded-3xl bg-white/50 border border-white shadow-sm">
              <div id="userAvatar" class="w-16 h-16 rounded-2xl bg-gradient-to-tr from-indigo-50 to-blue-50 border border-indigo-100 flex items-center justify-center text-indigo-600 text-2xl font-black">
                <span id="userInitial">U</span>
              </div>
              <div>
                <p class="text-sm font-bold text-indigo-600 mb-0.5" id="userRank">계급</p>
                <h2 class="text-2xl font-black text-gray-800 tracking-tight leading-none" id="userName">이름</h2>
                <p class="text-sm text-gray-500 font-mono mt-1" id="serviceNumber">군번</p>
              </div>
            </div>

            <div id="aiAssistPanel" class="p-4 rounded-2xl border shadow-sm hidden">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-xs font-black uppercase tracking-wider flex items-center gap-1.5" id="aiAssistTitle">
                  <i class="fa-solid fa-robot"></i> AI 심의 보조
                </span>
                <span class="text-[10px] font-bold px-2 py-0.5 rounded-full" id="aiScoreBadge"></span>
              </div>
              <p id="aiAssistMessage" class="font-medium text-sm text-gray-700 leading-snug"></p>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="p-5 rounded-3xl bg-white/40 border border-white/80 shadow-sm flex flex-col justify-center">
                <span class="text-xs font-bold text-gray-400 mb-1 uppercase tracking-wider">출타 기간</span>
                <strong id="leaveDates" class="text-lg font-bold text-gray-800"></strong>
              </div>
              <div id="daysBox" class="p-5 rounded-3xl bg-indigo-50/50 border border-indigo-100/50 flex flex-col justify-center items-end text-right">
                <span id="daysLabel" class="text-xs font-bold text-indigo-400 mb-1 uppercase tracking-wider">사용/취소 일수</span>
                <div class="flex items-baseline gap-1">
                  <strong id="totalDays" class="text-3xl font-black text-indigo-600"></strong>
                  <span id="daysUnit" class="text-sm font-bold text-indigo-400">일</span>
                </div>
              </div>
              <div class="col-span-2 p-5 rounded-3xl bg-white/40 border border-white/80 shadow-sm">
                <span class="text-xs font-bold text-gray-400 mb-2 uppercase tracking-wider block">상세 사유 / 행선지</span>
                <p id="leaveReason" class="text-gray-700 font-medium leading-relaxed"></p>
              </div>

              <div id="evidenceSection" class="col-span-2 p-5 rounded-3xl bg-slate-50 border border-slate-100 shadow-sm">
                <span class="text-xs font-bold text-gray-400 mb-3 uppercase tracking-wider flex items-center gap-1.5">
                  <i class="fa-solid fa-paperclip"></i> 첨부된 증빙 서류
                </span>
                <div id="evidenceFilesContainer" class="flex flex-wrap gap-2"></div>
              </div>
            </div>

            <div class="mt-6 border-t border-gray-100 pt-5">
              <h4 class="text-sm font-black text-gray-800 mb-3 flex items-center gap-2">
                <i class="fa-solid fa-clock-rotate-left text-indigo-500"></i> 신청일 기준 최근 출타 기록
                <span class="text-[10px] font-medium text-gray-400 font-mono bg-gray-100 px-1.5 py-0.5 rounded" id="historyBaseDateBadge"></span>
              </h4>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                <div class="bg-emerald-50/50 border border-emerald-100 rounded-xl p-3">
                  <div class="text-[10px] font-bold text-emerald-800 border-b border-emerald-100 pb-2 mb-2">외출</div>
                  <div id="historyOuting" class="space-y-2 text-[11px] text-gray-600"></div>
                </div>
                <div class="bg-blue-50/50 border border-blue-100 rounded-xl p-3">
                  <div class="text-[10px] font-bold text-blue-800 border-b border-blue-100 pb-2 mb-2">외박</div>
                  <div id="historyOvernight" class="space-y-2 text-[11px] text-gray-600"></div>
                </div>
                <div class="bg-purple-50/50 border border-purple-100 rounded-xl p-3">
                  <div class="text-[10px] font-bold text-purple-800 border-b border-purple-100 pb-2 mb-2">휴가</div>
                  <div id="historyVacation" class="space-y-2 text-[11px] text-gray-600"></div>
                </div>
              </div>
            </div>

            <div class="flex gap-3 pt-4 border-t border-gray-100/50">
              <button id="rejectBtn" onclick="rejectLeave()" class="flex-1 py-4 rounded-2xl bg-white text-red-500 font-bold text-base border border-gray-100 shadow-sm hover:bg-red-50 transition-all">
                거절
              </button>
              <button id="approveBtn" onclick="submitReview()" class="flex-[2] py-4 rounded-2xl bg-gray-900 text-white font-bold text-base shadow-xl shadow-gray-900/20 hover:bg-indigo-600 transition-all flex justify-center items-center gap-2">
                <i class="fa-solid fa-check" id="approveIcon"></i>
                <span id="approveText">검토 완료</span>
              </button>
            </div>
          </div>
        </div>
      </div>

      <script>
        window.initReviewPage = async function() {
          const token = localStorage.getItem("token");
          const urlParams = new URLSearchParams(window.location.search);
          const leaveId = urlParams.get("id");
          let isCancelRequest = false;

          if (!token || !leaveId) return spaNavigate('/');

          const setVal = (id, val, isHTML = false) => {
            const el = document.getElementById(id);
            if (el) { isHTML ? el.innerHTML = val : el.innerText = val; }
          };

          const loadingEl = document.getElementById("loading");
          const contentEl = document.getElementById("leave-content");
          if (loadingEl) loadingEl.classList.remove("hidden");
          if (contentEl) contentEl.classList.add("hidden");
          
          try {
            const res = await fetch(`/leaves/detail/${leaveId}`, { headers: { Authorization: `Bearer ${token}` } });
            if (res.status === 401) { localStorage.removeItem("token"); window.location.href = "/login.html"; return; }
            const data = await res.json();
            if (!data.success || !data.leave) return spaNavigate('/');
            
            const leave = data.leave;
            const user = leave.userId;

            if (leave.status === "CANCEL_REQ_REVIEW") {
              isCancelRequest = true;
              document.querySelector('body')?.classList.add("cancel-mode");
              const sb = document.getElementById("statusBadge");
              if (sb) sb.className = "inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-100/50 border border-orange-200 text-orange-700 text-xs font-bold mb-4 shadow-sm";
              setVal("mainTitle", `휴가 취소 <span class="text-orange-600 font-light">검토 결재</span>`, true);
              const db = document.getElementById("daysBox");
              if(db) db.className = "p-5 rounded-3xl bg-orange-50 border border-orange-100 flex flex-col justify-center items-end text-right";
              const td = document.getElementById("totalDays");
              if(td) td.className = "text-3xl font-black text-orange-600";
              setVal("rejectBtn", "취소 거절 (휴가유지)");
              setVal("approveText", "취소 결재 완료 (승인자로 전달)");
            }

            const name = user?.name || "알수없음";
            setVal("unitNameDisplay", localStorage.getItem("unitName") || "소속부대");
            setVal("userInitial", name.charAt(0));
            setVal("userName", name);
            setVal("serviceNumber", user?.serviceNumber || "");
            
            setVal("userRank", (function() {
                if (!user || !user.promoToIlbyung) return user?.rank || "계급 미상";
                const today = new Date();
                if (today >= new Date(user.promoToByungjang)) return "병장";
                if (today >= new Date(user.promoToSangbyung)) return "상병";
                if (today >= new Date(user.promoToIlbyung)) return "일병";
                return "이병";
            })());

            setVal("leaveDates", `${leave.startDate.split("T")[0].replace(/-/g, ".")} ~ ${leave.endDate.split("T")[0].replace(/-/g, ".")}`);
            setVal("totalDays", leave.totalDaysUsed);
            setVal("leaveReason", leave.reason);

            if (!isCancelRequest) {
              const aiPanel = document.getElementById("aiAssistPanel");
              if (aiPanel) aiPanel.classList.remove("hidden");
              setVal("aiScoreBadge", `우선순위: ${leave.priorityScore || 0}점`);
              
              if (leave.isWaitlisted) {
                if (aiPanel) aiPanel.className = "p-4 rounded-2xl border bg-orange-50 border-orange-200 shadow-sm";
                setVal("aiAssistTitle", `<i class="fa-solid fa-robot"></i> AI 심의 보조`, true);
                setVal("aiAssistMessage", "⚠️ <strong>[출타율 초과 - 후보]</strong> 정원이 초과되었습니다. <strong>반려를 권장</strong>합니다.", true);
              } else if (leave.isManualOverride) {
                if (aiPanel) aiPanel.className = "p-4 rounded-2xl border bg-blue-50 border-blue-200 shadow-sm";
                setVal("aiAssistTitle", `<i class="fa-solid fa-robot"></i> AI 심의 보조`, true);
                setVal("aiAssistMessage", "🔒 <strong>[관리자 수동 고정]</strong> 관리자가 고정한 인원입니다. <strong>승인을 권장</strong>합니다.", true);
              } else {
                if (aiPanel) aiPanel.className = "p-4 rounded-2xl border bg-emerald-50 border-emerald-200 shadow-sm";
                setVal("aiAssistTitle", `<i class="fa-solid fa-robot"></i> AI 심의 보조`, true);
                setVal("aiAssistMessage", "✅ <strong>[정규 편성]</strong> 정원 내에 안전하게 편성되었습니다. <strong>승인을 권장</strong>합니다.", true);
              }
            }

            const evidenceContainer = document.getElementById("evidenceFilesContainer");
            if (evidenceContainer) {
              if (leave.evidenceFiles && leave.evidenceFiles.length > 0) {
                evidenceContainer.innerHTML = leave.evidenceFiles.map((url, i) => 
                  `<a href="${url}" target="_blank" class="inline-flex items-center gap-2 px-3 py-2 bg-white border border-gray-200 rounded-xl shadow-sm hover:text-indigo-600 transition-all text-[11px] font-bold text-gray-700"><i class="fa-solid fa-file-arrow-down text-indigo-500"></i> 서류 #${i + 1}</a>`
                ).join("");
              } else {
                evidenceContainer.innerHTML = `<div class="w-full text-center py-4 text-gray-400 text-xs font-bold bg-white/30 rounded-xl border border-dashed border-gray-200">증빙 서류 없음</div>`;
              }
            }

            if (user?._id) {
              const hRes = await fetch(`/leaves/user-history/${user._id}?beforeDate=${leave.startDate.split("T")[0]}`, { headers: { Authorization: `Bearer ${token}` } });
              const hData = await hRes.json();
              if (hData.success) {
                setVal("historyBaseDateBadge", `기준: ${leave.startDate.split("T")[0]} 이전`);
                const renderH = (id, list) => {
                  const el = document.getElementById(id);
                  if (el) {
                    el.innerHTML = list.length === 0 ? `<div class="text-gray-400 py-1">기록 없음</div>` : list.map(r => `
                      <div class="bg-white p-2 rounded-lg border border-gray-100 shadow-sm mb-1">
                        <div class="font-bold text-gray-800">${r.startDate.slice(5,10)} ~ ${r.endDate.slice(5,10)}</div>
                        <div class="truncate text-gray-400 text-[10px]">${r.reason}</div>
                      </div>`).join("");
                  }
                };
                renderH("historyOuting", hData.history["외출"]);
                renderH("historyOvernight", hData.history["외박"]);
                renderH("historyVacation", hData.history["휴가"]);
              }
            }

            if (loadingEl) loadingEl.classList.add("hidden");
            if (contentEl) contentEl.classList.remove("hidden");

          } catch (err) {
            console.error(err);
            alert("데이터를 불러오는데 실패했습니다.");
          }
        };

        window.rejectLeave = async function() {
          const leaveId = new URLSearchParams(window.location.search).get("id");
          if (!confirm("이 신청을 거절하시겠습니까?")) return;
          const res = await fetch(`/leaves/${leaveId}/reject`, { method: "PUT", headers: { Authorization: `Bearer ${localStorage.getItem("token")}` } });
          if (res.status === 401) return window.location.href = "/login.html";
          if ((await res.json()).success) spaNavigate('/');
        };

        window.submitReview = async function() {
          const leaveId = new URLSearchParams(window.location.search).get("id");
          if (!confirm("검토 완료하시겠습니까?")) return;
          const res = await fetch(`/leaves/${leaveId}/review`, { method: "PUT", headers: { Authorization: `Bearer ${localStorage.getItem("token")}`, "Content-Type": "application/json" } });
          if (res.status === 401) return window.location.href = "/login.html";
          if ((await res.json()).success) spaNavigate('/');
        };

        if (document.getElementById('leave-content') && document.getElementById('leave-content').classList.contains('hidden')) { 
          window.initReviewPage(); 
        }
      </script>
    </div>
  </body>
</html>