<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SmartMil - 계정 설정</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        @import url("https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css");
        body { font-family: "Pretendard", sans-serif; }
        .mesh-bg { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; overflow: hidden; background-color: #f8fafc; }
        .blob { position: absolute; filter: blur(90px); opacity: 0.65; animation: float 12s infinite alternate ease-in-out; }
        .blob-1 { top: -10%; left: -10%; width: 50vw; height: 50vw; background: radial-gradient(circle, rgba(99, 102, 241, 0.3) 0%, rgba(99, 102, 241, 0) 70%); }
        .blob-2 { bottom: -20%; right: -10%; width: 60vw; height: 60vw; background: radial-gradient(circle, rgba(168, 85, 247, 0.2) 0%, rgba(168, 85, 247, 0) 70%); animation-delay: -5s; }
        @keyframes float { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(30px, 50px) scale(1.1); } }
        .glass-card { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.9); box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.05); border-radius: 1.5rem; }
    </style>
</head>
<body class="bg-gray-50 text-slate-800 overflow-hidden h-screen flex flex-col relative selection:bg-indigo-500 selection:text-white">

    <%- include('partials/sidebar') %>
    <%- include('partials/header') %>

    <div id="page-wrapper" class="flex-1 w-full h-full relative overflow-hidden flex flex-col">
        
        <div class="mesh-bg">
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
        </div>

        <main class="flex-1 overflow-y-auto custom-scrollbar w-full relative z-10">
            <div class="max-w-3xl mx-auto pt-8 px-4 sm:px-6 pb-20 space-y-6">
                <section class="glass-card p-6 sm:p-8 flex items-center gap-6 relative overflow-hidden">
                    <div class="absolute -right-6 -top-6 w-32 h-32 bg-indigo-50 rounded-full blur-2xl opacity-60 pointer-events-none"></div>
                    <div class="w-20 h-20 sm:w-24 sm:h-24 bg-gradient-to-tr from-indigo-500 to-purple-500 rounded-full flex items-center justify-center text-white text-3xl font-black shadow-lg shrink-0" id="profileInitial">U</div>
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                            <span id="profileRank" class="px-2.5 py-1 bg-indigo-100 text-indigo-700 rounded-md text-xs font-black shadow-sm">계급</span>
                            <span id="profileRole" class="text-[11px] font-bold text-gray-500 bg-gray-100 px-2 py-1 rounded-md border border-gray-200">역할</span>
                        </div>
                        <h2 id="profileName" class="text-2xl sm:text-3xl font-black text-gray-900 tracking-tight">이름 불러오는 중...</h2>
                        <p class="text-sm font-mono text-gray-500 mt-1"><i class="fa-solid fa-id-badge mr-1.5"></i><span id="profileServiceNum">00-00000000</span></p>
                        <p class="text-sm font-medium text-gray-600 mt-1"><i class="fa-solid fa-building-shield mr-1.5"></i><span id="profileUnit">소속 부대</span></p>
                    </div>
                </section>

                <section id="ddaySection" class="glass-card p-6 sm:p-8 hidden">
                    <h3 class="text-lg font-black text-gray-800 mb-6 flex items-center gap-2"><i class="fa-solid fa-stopwatch text-indigo-500"></i> 복무 상태 및 진급 정보</h3>
                    <div class="bg-indigo-600 rounded-2xl p-6 text-white shadow-lg relative overflow-hidden mb-6">
                        <p class="text-indigo-100 font-bold text-sm mb-1">전역까지 남은 시간</p>
                        <div class="flex items-end justify-between mb-4">
                            <h4 class="text-4xl sm:text-5xl font-black tracking-tighter" id="dischargeDday">D-0</h4>
                            <span class="text-sm font-bold bg-white/20 px-3 py-1 rounded-full backdrop-blur-sm" id="progressPercent">0%</span>
                        </div>
                        <div class="w-full h-3 bg-indigo-900/50 rounded-full overflow-hidden shadow-inner">
                            <div id="progressBar" class="h-full bg-emerald-400 rounded-full transition-all duration-1000 ease-out" style="width: 0%"></div>
                        </div>
                        <div class="flex justify-between text-xs text-indigo-200 mt-2 font-mono font-bold">
                            <span id="enlistDate">입대일: -</span>
                            <span id="dischargeDate">전역일: -</span>
                        </div>
                    </div>
                    <div class="bg-gray-50 border border-gray-100 rounded-xl p-5 flex items-center justify-between">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-xl text-yellow-500 shadow-sm border border-gray-100"><i class="fa-solid fa-angles-up"></i></div>
                            <div>
                                <p class="text-xs font-bold text-gray-500 mb-0.5">다음 진급 목표</p>
                                <p class="text-lg font-black text-gray-800" id="nextPromoTarget">계산 중...</p>
                            </div>
                        </div>
                        <div class="text-right"><p class="text-xl font-black text-indigo-600" id="nextPromoDday">D-0</p></div>
                    </div>
                </section>

                <section class="glass-card p-6 sm:p-8">
                    <h3 class="text-lg font-black text-gray-800 mb-6 flex items-center gap-2"><i class="fa-solid fa-shield-halved text-indigo-500"></i> 보안 설정</h3>
                    <div class="space-y-4 max-w-md">
                        <p class="text-xs font-bold text-red-500 bg-red-50 p-3 rounded-xl border border-red-100 mb-4 hidden" id="forceChangeWarning">
                            <i class="fa-solid fa-triangle-exclamation mr-1"></i>보안을 위해 비밀번호를 반드시 변경해야 합니다!
                        </p>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1.5">현재 비밀번호</label>
                            <input type="password" id="oldPassword" class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl outline-none" placeholder="현재 비밀번호를 입력하세요" />
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1.5">새 비밀번호</label>
                            <input type="password" id="newPassword" class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl outline-none" placeholder="새로운 비밀번호 (6자리 이상)" />
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1.5">새 비밀번호 확인</label>
                            <input type="password" id="confirmPassword" class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl outline-none" placeholder="새로운 비밀번호를 다시 입력하세요" />
                        </div>
                        <button onclick="changePassword()" class="mt-4 px-6 py-2.5 bg-gray-800 text-white font-bold rounded-xl shadow-md hover:bg-gray-900 transition-colors">비밀번호 변경</button>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <script src="/common.js"></script>
    <script>
        // 🚀 設定頁專屬初始化函數 (供 SPA 引擎呼叫)
        window.loadSettingsPage = async function() {
            console.log("Settings Page Initializing...");
            await loadSettingsProfileData();
        };

        // 頁面加載時執行
        document.addEventListener("DOMContentLoaded", () => {
            window.loadSettingsPage();
        });

        function formatDate(dateStr) {
            if (!dateStr) return "-";
            const d = new Date(dateStr);
            return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, "0")}.${String(d.getDate()).padStart(2, "0")}`;
        }

        async function loadSettingsProfileData() {
            const token = localStorage.getItem("token");
            if (!token) return;
            try {
                const res = await fetch("/profile", { headers: { Authorization: `Bearer ${token}` } });
                const data = await res.json();
                if (data.user) {
                    const u = data.user;
                    const roleMapLocal = { soldier: "용사", officer: "간부", reviewer: "검토자", approver: "승인자" };
                    const roleStr = roleMapLocal[u.role] || u.role;

                    document.getElementById("profileName").innerText = u.name || "알 수 없음";
                    document.getElementById("profileInitial").innerText = (u.name || "U").charAt(0);
                    document.getElementById("profileServiceNum").innerText = u.serviceNumber || "-";
                    document.getElementById("profileRank").innerText = u.rank || "계급없음";
                    document.getElementById("profileRole").innerText = roleStr;
                    document.getElementById("profileUnit").innerText = u.orgName || "소속 부대 없음";

                    if (u.forceChangePassword) document.getElementById("forceChangeWarning").classList.remove("hidden");
                    if (u.role === "soldier") {
                        document.getElementById("ddaySection").classList.remove("hidden");
                        calculateDdays(u);
                    }
                }
            } catch (err) { console.error("抓取個人資料失敗", err); }
        }

        function calculateDdays(user) {
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (user.enlistmentDate && user.dischargeDate) {
                const enlist = new Date(user.enlistmentDate);
                const discharge = new Date(user.dischargeDate);
                document.getElementById("enlistDate").innerText = `입대일: ${formatDate(enlist)}`;
                document.getElementById("dischargeDate").innerText = `전역일: ${formatDate(discharge)}`;

                const totalDays = (discharge - enlist) / (1000 * 60 * 60 * 24);
                const servedDays = (today - enlist) / (1000 * 60 * 60 * 24);
                const remainDays = Math.ceil((discharge - today) / (1000 * 60 * 60 * 24));

                if (remainDays > 0) {
                    document.getElementById("dischargeDday").innerText = `D-${remainDays}`;
                    let percent = Math.floor((servedDays / totalDays) * 100);
                    percent = percent < 0 ? 0 : (percent > 100 ? 100 : percent);
                    document.getElementById("progressPercent").innerText = `${percent}%`;
                    setTimeout(() => { document.getElementById("progressBar").style.width = `${percent}%`; }, 300);
                } else {
                    document.getElementById("dischargeDday").innerText = "🎉 전역 완료";
                    document.getElementById("progressPercent").innerText = "100%";
                    document.getElementById("progressBar").style.width = "100%";
                    document.getElementById("progressBar").classList.replace("bg-emerald-400", "bg-yellow-400");
                }
            }

            const promoTargets = [
                { rank: "일병", date: user.promoToIlbyung },
                { rank: "상병", date: user.promoToSangbyung },
                { rank: "병장", date: user.promoToByungjang },
            ];
            let nextTarget = promoTargets.find(t => t.date && new Date(t.date) > today);
            const targetEl = document.getElementById("nextPromoTarget");
            const ddayEl = document.getElementById("nextPromoDday");

            if (nextTarget) {
                const remain = Math.ceil((new Date(nextTarget.date) - today) / (1000 * 60 * 60 * 24));
                targetEl.innerText = `${nextTarget.rank} 진급 (${formatDate(nextTarget.date)})`;
                ddayEl.innerText = `D-${remain}`;
            } else {
                targetEl.innerText = "⭐ 최고 계급 도달";
                ddayEl.innerText = "무사 전역 기원!";
                ddayEl.className = "text-sm font-bold text-indigo-600";
            }
        }

        async function changePassword() {
            const oldPassword = document.getElementById("oldPassword").value;
            const newPassword = document.getElementById("newPassword").value;
            const confirmPassword = document.getElementById("confirmPassword").value;
            if (!oldPassword || !newPassword || !confirmPassword) return alert("모든 칸을 입력해주세요.");
            if (newPassword.length < 6) return alert("새 비밀번호는 6자리 이상이어야 합니다.");
            if (newPassword !== confirmPassword) return alert("새 비밀번호가 일치하지 않습니다.");

            try {
                const res = await fetch("/profile/password", {
                    method: "PUT",
                    headers: { "Content-Type": "application/json", Authorization: `Bearer ${localStorage.getItem("token")}` },
                    body: JSON.stringify({ oldPassword, newPassword }),
                });
                const data = await res.json();
                if (data.success) {
                    alert("비밀번호가 변경되었습니다. 다시 로그인해주세요.");
                    localStorage.removeItem("token");
                    window.location.href = "/login.html";
                } else alert(data.error || "변경 실패");
            } catch (error) { alert("서버 오류"); }
        }
    </script>
</body>
</html>